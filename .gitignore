# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
venv/
.venv/
env/
.env/
ENV/

# Logs (keep directory, ignore contents)
logs/*.log
logs/*.log.*
logs/.history

# Screenshots (keep directory, ignore captures)
screenshots/*.png
screenshots/*.jpg
agent/screenshots/*.png
agent/screenshots/*.jpg

# Backups (generated by backup skill)
backups/

# IDE
.vscode/
.idea/
*.swp
*.swo
*.DS_Store
Thumbs.db

# Secrets — NEVER commit real tokens
# config.toml is committed WITH placeholder tokens (CHANGE_ME_*)
# agent.toml is committed WITH placeholder tokens

# Distribution
*.whl
*.tar.gz
MANIFEST

# Test artifacts
.pytest_cache/
.coverage
htmlcov/
_test_*.py
